{
  "functions": {
    "source": "functions",
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR/../../../packages/shared\" run build",
      "rm -rf \"$RESOURCE_DIR/shared\" && mkdir -p \"$RESOURCE_DIR/shared\" && cp -R \"$RESOURCE_DIR/../../../packages/shared/dist\" \"$RESOURCE_DIR/../../../packages/shared/package.json\" \"$RESOURCE_DIR/shared/\"",
      "cd \"$RESOURCE_DIR\" && npm install",
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "site": "memetrest-b57dc",
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
