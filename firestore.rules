rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }

    function isModerator() {
      return isSignedIn() && getUserRole() in ['admin', 'moderator'];
    }

    function userIsActive() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';
    }

    function isUploadAssetPublic(assetData) {
      return assetData.status == 'published' && assetData.visibility == 'public';
    }

    function isUploadAssetOwner(assetId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/assets/$(assetId)).data.ownerId == request.auth.uid;
    }

    // ── users/{uid} ───────────────────────────────────────────────────
    // Anyone can read profiles. Only the owner can create/update their
    // own doc (except role/status, which only admins can change).
    match /users/{uid} {
      allow read: if true;

      // Owner creates their own profile on first login
      allow create: if isOwner(uid)
        && request.resource.data.role == 'user'
        && request.resource.data.status == 'active';

      // Owner can update non-privileged fields (role and status must stay the same)
      allow update: if isOwner(uid)
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status
        // Upload enforcement fields are backend-authoritative in this phase.
        && request.resource.data.uploadProfile == resource.data.uploadProfile;

      // Admin can change any field (including role/status)
      allow update: if isAdmin();

      allow delete: if false;
    }

    // ── profileAssets/{assetId} ───────────────────────────────────────
    // Public read for asset pickers and profile rendering.
    // Writes are admin-only (presets managed via scripts/Admin SDK).
    match /profileAssets/{assetId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── usernames/{username} ──────────────────────────────────────────
    // Username uniqueness index. Reads are public (for availability
    // checks). Creates/deletes happen inside transactions from the
    // client, guarded by ownership checks.
    match /usernames/{username} {
      allow read: if true;

      // Only authenticated users can claim a username, and the doc
      // must record their own UID.
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;

      // Only the owner of the username doc (or an admin) can delete it.
      allow delete: if isSignedIn()
        && (resource.data.uid == request.auth.uid || isAdmin());

      allow update: if false;
    }

    // ── memes/{memeId} ────────────────────────────────────────────────
    match /memes/{memeId} {
      // Public gallery: anyone can read approved memes.
      // Moderators & admins can read all memes.
      // The uploader can read their own memes regardless of status.
      allow read: if resource.data.status == 'approved'
        || (isSignedIn() && resource.data.uploadedBy == request.auth.uid)
        || isModerator();

      // Authenticated, active users can create memes.
      // New memes must default to status=pending and set uploadedBy to the caller.
      allow create: if isSignedIn()
        && userIsActive()
        && request.resource.data.status == 'pending'
        && request.resource.data.uploadedBy == request.auth.uid;

      // Only moderators/admins can change the status (approve/reject).
      allow update: if isModerator();

      allow delete: if isAdmin();
    }

    // ── assets/{assetId} ───────────────────────────────────────────────
    // Upload-domain canonical asset docs are backend-authoritative in this phase.
    match /assets/{assetId} {
      // Canonical visibility rule: published + public only.
      // Private docs are owner/moderator only.
      // NOTE: uses resource.data.ownerId directly (not the get()-based helper)
      // so Firestore can evaluate list-query constraints against the rule.
      allow read: if isUploadAssetPublic(resource.data)
        || (isSignedIn() && resource.data.ownerId == request.auth.uid)
        || isModerator();

      // Client writes are blocked; backend handlers (Admin SDK) own mutations.
      allow create, update, delete: if false;

      // ── assets/{assetId}/events/{eventId} ───────────────────────────
      // Event history is backend-authored and immutable from clients.
      match /events/{eventId} {
        allow read: if isUploadAssetOwner(assetId) || isModerator();
        allow create, update, delete: if false;
      }
    }
  }
}
