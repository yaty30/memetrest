{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "lib",
    "rootDir": ".."
  },
  "include": [
    "src/**/*.ts",
    "../src/services/uploadDefaults.ts",
    "../src/services/uploadGuards.ts",
    "../src/utils/uploadStoragePaths.ts",
    "../src/types/upload.ts"
  ]
}