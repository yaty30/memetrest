rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Storage path strategy ─────────────────────────────────────────
    // Uploads: uploads/{uid}/{filename}
    //
    // • Only the owning user can write to their own folder.
    // • Anyone can read (approved assets serve public URLs).
    //   Visibility control is handled at the Firestore layer.
    // • Max upload size: 10 MB.
    // • Allowed content types: image/jpeg, image/png, image/webp, image/gif.

    match /uploads/{uid}/{allPaths=**} {
      // Anyone can read — public gallery URLs
      allow read: if true;

      // Only the authenticated owner can upload to their own path
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp|gif)');

      allow delete: if request.auth != null
        && request.auth.uid == uid;
    }
  }
}
